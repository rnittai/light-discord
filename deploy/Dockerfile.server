FROM rust:1.95-slim-bookworm AS build

WORKDIR /app
COPY . .
RUN cargo build --release -p light-discord-server

FROM debian:bookworm-slim

RUN useradd --system --create-home --uid 10001 lightdiscord
COPY --from=build /app/target/release/light-discord-server /usr/local/bin/light-discord-server

USER lightdiscord
ENV LD_TCP_BIND=0.0.0.0:41610
ENV LD_UDP_BIND=0.0.0.0:41611

EXPOSE 41610/tcp
EXPOSE 41611/udp

CMD ["light-discord-server"]

